                    .params-table__row
                      .params-table__label Полная масса а/м, кг
                      .params-table__value 50000
                    .params-table__row
                      .params-table__label нагрузка на заднюю тележку, кг
                      .params-table__value 32000
                    .params-table__row
                      .params-table__label нагрузка на первую и вторую оси, кг
                      .params-table__value 18000
                    .params-table__row
                      .params-table__label Снаряженная масса, кг
                      .params-table__value 17565
                    .params-table__row
                      .params-table__label нагрузка на заднюю тележку, кг
                      .params-table__value 8045
                    .params-table__row
                      .params-table__label нагрузка на первую и вторую оси, кг
                      .params-table__value 9520
            .auto-page-accordions__block
              .auto-page-accordions__up
                span.auto-page-accordions__caption ДВИГАТЕЛЬ
                .auto-page-accordions__arrow
                  +icon('accordion-arrow')
              .auto-page-accordions__dropdown
                .auto-page-accordions__content
                  .params-table
                    .params-table__row
                      .params-table__label Модель двигателя
                      .params-table__value Mercedes-Benz OM 457LA.V/4Макс. 
                    .params-table__row
                      .params-table__label полезный крутящий момент, Нм (кгсм)
                      .params-table__value 2100 (214)
                    .params-table__row
                      .params-table__label частоте вращения коленчатого вала, об/мин
                      .params-table__value 1100
                    .params-table__row
                      .params-table__label Максимальная полезная мощность, кВт (л.с.)
                      .params-table__value 315 (428)
                    .params-table__row
                      .params-table__label при частоте вращения коленчатого вала, об/мин
                      .params-table__value 1900
                    .params-table__row
                      .params-table__label Рабочий объем, л
                      .params-table__value 11,97
                    .params-table__row
                      .params-table__label Расположение и число цилиндров
                      .params-table__value рядное, 6
                    .params-table__row
