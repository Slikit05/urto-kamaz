block body
  section.up-section-bg.up-section-bg_change.gray-bg
    section.bread-crumbs
      .container
        +breadcrumbs({
          items: breadcrumbs,
        })

    section.line-title-page.line-title-page_lg-offset
      .container
        .line-title-page__wrapper
          h1.title-page Автомобиль КАМАЗ 4308-69 8,5 м.
          .line-title-page__row
            +tag({
              text: 'назад к списку',
              className: 'yellow reverse',
            })

    section.first-slider.change-slider
      .first-slider__container.swiper.js-firstSliderAuto
        .first-slider__wrapper.swiper-wrapper
          each item in firstScreenSlider
            .first-slider__slide.swiper-slide
              .first-slider__item
                +picture({
                  'x1': 'img/' + item.img + '.jpg',
                  'x2': 'img/' + item.img + '@2x.jpg',
                })
      //- .first-slider__pagination.js-firstSliderAutoPagination

      .first-slider__arrows
        .container
          .first-slider__flex-arrows
            .first-slider__arrow.prev.js-firstSliderAutoButtonPrev
              svg(width="13" height="22" viewBox="0 0 13 22" xmlns="http://www.w3.org/2000/svg")
                path(d="M11.4142 0.707108L1.41419 10.7071L11.4142 20.7071" stroke="currentColor" fill="transparent" stroke-width="2")
                path(class="arrow-tail" d="M1.41406 10.7071 L31.4141 10.7071" stroke="currentColor" stroke-width="2" stroke-dasharray="30" stroke-dashoffset="30")
              .first-slider__arrow-mob
                .first-slider__wrap-icon
                  svg(viewBox="0 0 26 10" xmlns="http://www.w3.org/2000/svg")
                    path(d="M5.41406 8.70715L1.41406 4.70715M1.41406 4.70715L5.41406 0.707152" stroke="currentColor" stroke-width="2")
                    path(class="arrow-tail" d="M1.41406 4.70715 L25.4141 4.70715" stroke="currentColor" stroke-width="2")
                span Предыдущая
            .first-slider__arrow.next.js-firstSliderAutoButtonNext
              svg(width="13" height="22" viewBox="0 0 13 22" xmlns="http://www.w3.org/2000/svg")
                path(d="M11.4142 0.707108L1.41419 10.7071L11.4142 20.7071" stroke="currentColor" fill="transparent" stroke-width="2")
                path(class="arrow-tail" d="M1.41406 10.7071 L31.4141 10.7071" stroke="currentColor" stroke-width="2" stroke-dasharray="30" stroke-dashoffset="30")
              .first-slider__arrow-mob
                span Следующая
                .first-slider__wrap-icon
                  svg(viewBox="0 0 26 10" xmlns="http://www.w3.org/2000/svg")
                    path(d="M5.41406 8.70715L1.41406 4.70715M1.41406 4.70715L5.41406 0.707152" stroke="currentColor" stroke-width="2")
                    path(class="arrow-tail" d="M1.41406 4.70715 L25.4141 4.70715" stroke="currentColor" stroke-width="2")

    section.first-slider-tumbs
      .container
        .sm-container
          .first-slider-tumbs__container.swiper.js-firstSliderAutoTumbs
            .first-slider-tumbs__wrapper.swiper-wrapper
              each item in firstSliderAutoTumbs
                .first-slider-tumbs__slide.swiper-slide
                  .first-slider-tumbs__item
                    +picture({
                      'x1': 'img/' + item.img + '.jpg',
                      'x2': 'img/' + item.img + '@2x.jpg',
                    })
    
    section.auto-page-line
      .container
        .sm-container
          .auto-page-line__wrapper
            span.auto-page-line__price 7 300 000 ₽
            +button({
              text: 'купить',
              theme: 'yellow',
              elemHref: '#',
              svgIconEnd: 'phone-2',
              className: 'phone-2-icon js-showModal',
              attrs: {
                'data-click-modal': 'PayModal'
              }
            })
            +button({
              text: 'лизинг',
              theme: 'yellow',
              elemHref: '#',
              svgIconEnd: 'procent',
              className: 'procent-icon js-showModal',
              attrs: {
                'data-click-modal': 'leasingModal'
              }
            })
            +button({
              text: 'нужна помощь?',
              theme: 'yellow',
              elemHref: '#',
              svgIconEnd: 'gard',
              className: 'gard-icon js-showModal',
              attrs: {
                'data-click-modal': 'HelpModal'
              }
            })

            

    section.auto-page-accordions
      .container
        .sm-container
          .auto-page-accordions__wrapper
            .auto-page-accordions__block
              .auto-page-accordions__up
                span.auto-page-accordions__caption ВЕСОВЫЕ ПАРАМЕТРЫ И НАГРУЗКИ
                .auto-page-accordions__arrow
                  +icon('accordion-arrow')
              .auto-page-accordions__dropdown
