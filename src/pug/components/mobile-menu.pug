mixin mobile-menu({arr})
  .mobile-menu
    .container
      .mobile-menu__wrapper
        nav.mobile-menu__navigation
          .mobile-menu__wrap.mobile-menu__wrap_accordion
            .mobile-menu__up
              span.mobile-menu__caption Каталог автотехники
              .mobile-menu__arrow.mobile-menu__arrow_accordion
                +icon('arrow')
            .mobile-menu__dropdown
              .mobile-menu__content
                +vehicle-catalog({
                  arr: arr,
                  noneTitle: true,
                })

          .mobile-menu__wrap
            .mobile-menu__up
              span.mobile-menu__caption Сервис и гарантийные обязательства
              .mobile-menu__arrow
                +icon('arrow')
          .mobile-menu__wrap
            .mobile-menu__up
              span.mobile-menu__caption Запасные части
              .mobile-menu__arrow
                +icon('arrow')
          .mobile-menu__wrap
            .mobile-menu__up
              span.mobile-menu__caption Финансовый сервис
              .mobile-menu__arrow
                +icon('arrow')
          .mobile-menu__wrap
            .mobile-menu__up
              span.mobile-menu__caption Акции
              .mobile-menu__arrow
                +icon('arrow')
          .mobile-menu__wrap.mobile-menu__wrap_accordion
            .mobile-menu__up
              span.mobile-menu__caption О компании
              .mobile-menu__arrow.mobile-menu__arrow_accordion
                +icon('arrow')
            .mobile-menu__dropdown
              .mobile-menu__content
                ul.mobile-menu__list
                  li.mobile-menu__item
                    a.mobile-menu__link(href="") 
                      span Компания
                      +icon('arrow')
                  li.mobile-menu__item
                    a.mobile-menu__link(href="")  
                      span Отзывы
                      +icon('arrow')
                  li.mobile-menu__item
                    a.mobile-menu__link(href="")  
                      span Новости
                      +icon('arrow')
                  li.mobile-menu__item
                    a.mobile-menu__link(href="")  
                      span Контакты
                      +icon('arrow')

        .mobile-menu__bottom
          span.total-addres г. Краснодар, ул. Ростовское ш., 47
          .mobile-menu__row
            a.link-tell(href="tel:88002220409") 
              +icon('phone')
              span 8 800 222 04 09
            a.mobile-menu__social(href="") 
              +icon('whatsapp')