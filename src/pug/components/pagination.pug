mixin pagination({ totalPages, currentPage })
  .pagination    
    .pagination__button.previous
      .pagination__arrow
        svg(viewBox="0 0 18 10" xmlns="http://www.w3.org/2000/svg")
          path(d="M12 8.70709L16 4.70709M16 4.70709L12 0.707092" stroke="currentColor" stroke-width="2")
          path(class="arrow-tail" d="M16 4.70709L0 4.70709" stroke="currentColor" stroke-width="2" stroke-dasharray="16" stroke-dashoffset="16")
      span предыдущая        
    ul.pagination__list
      li.pagination__item
        a.pagination__link(href="") 1
      li.pagination__item
        a.pagination__link.is-active(href="") 2
      li.pagination__item
        a.pagination__link(href="") 3
      li.pagination__item
        span.pagination__dots ...
      li.pagination__item
        a.pagination__link(href="") 12    
    .pagination__button.next
      span Следующая
      .pagination__arrow
        svg(viewBox="0 0 18 10" xmlns="http://www.w3.org/2000/svg")
          path(d="M12 8.70709L16 4.70709M16 4.70709L12 0.707092" stroke="currentColor" stroke-width="2")
          path(class="arrow-tail" d="M16 4.70709L0 4.70709" stroke="currentColor" stroke-width="2" stroke-dasharray="16" stroke-dashoffset="16")